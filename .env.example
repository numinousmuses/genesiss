# Copy to .env and fill in. Loaded by genesiss.config when present.

# Bridge server bind (used by Electron to reach Python)
GENESISS_HOST=127.0.0.1
GENESISS_PORT=8765

# Ollama
OLLAMA_HOST=http://127.0.0.1:11434

# Default model variant — one of: genesiss-4b, genesiss-9b, genesiss-20b, genesiss-27b
GENESISS_MODEL=genesiss-4b

# Optional: HF token for pulling private finetunes during model setup
HUGGINGFACE_TOKEN=
